{
  "name": "@quail-ai/azure-ai-provider",
  "version": "2.0.0",
  "description": "ai sdk compatible provider for azure(non OpenAI models)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:ci": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "echo 'Skipping tests as they are run in CI'"
  },
  "dependencies": {
    "@ai-sdk/provider": "^2.0.0",
    "@ai-sdk/provider-utils": "^3.0.1",
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-sse": "^2.3.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "ai": "^5.0.10",
    "dotenv": "^16.4.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuailAI/azure-ai-provider.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "azure",
    "ai",
    "AI SDK",
    "provider"
  ],
  "author": "Olaf Dsouza",
  "license": "MIT"
}
